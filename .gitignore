# ============================================
# Heavy media — NOT tracked (regeneratable or too big for LFS quota)
# ============================================
assets/audio/
assets/video/
assets/videos/
assets/raw/
assets/hyperframes/
assets/reels_video/
assets/stories_video/
assets/stories/
content/blogs/*/

# ============================================
# LFS-tracked critical artifacts (NOT ignored — see .gitattributes)
#   assets/slides/         (PDFs, HTMLs, PNGs, JPGs, fonts)
#   assets/social_posts/   (PNGs, HTMLs, fonts)
#   assets/carousels/      (HTMLs, PNGs)
#   content/worksheets/    (PDFs, HTMLs, fonts, svgs)
#   output/worksheets/     (PDFs)
# ============================================
