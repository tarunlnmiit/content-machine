  {
    "sceneId": "scene-05",
    "componentName": "CodeAnnotation",
    "script": "use & and | for boolean filters, not Python's and and or",
    "niche": "ds",
    "durationSec": 7,
    "props": {
      "code": [
        "high_value = df.loc[df['revenue'] > 10000, ['customer_id', 'revenue']]",
        "filtered = df[(df['region'] == 'North') & (df['revenue'] > 5000)]",
        "filtered_v2 = df.query(\"region == 'North' and revenue > 5000\")",
        "df[df['status'].isin(['active', 'trial'])]"
      ],
      "language": "python",
      "highlightLine": 2,
      "annotationText": "Use & and | on arrays, not and/or. Wrap each condition in parentheses."
    }
