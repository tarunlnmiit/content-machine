  {
    "sceneId": "scene-07",
    "componentName": "CodeAnnotation",
    "script": "The errors='coerce' argument is doing critical work here",
    "niche": "ds",
    "durationSec": 7,
    "props": {
      "code": [
        "df['order_date'] = pd.to_datetime(df['order_date'], errors='coerce')",
        "df['revenue'] = pd.to_numeric(df['revenue'], errors='coerce')",
        "df['region'] = df['region'].str.strip().str.title()",
        "df['age'] = df['age'].fillna(df['age'].median())",
        "df_deduped = df.drop_duplicates(subset=['order_id'], keep='first')"
      ],
      "language": "python",
      "highlightLine": 1,
      "annotationText": "errors='coerce' turns bad values into NaN instead of crashing \u2014 handle them intentionally, not at 2am."
    }
  },
  {
    "sceneId": "scene-08",
    "componentName": "CodeAnnotation",
    "script": "The .agg() pattern with named aggregations \u2014 commit that to memory",
    "niche": "ds",
    "durationSec": 8,
    "props": {
      "code": [
        "region_summary = df.groupby('region').agg(",
        "    total_revenue=('revenue', 'sum'),",
        "    avg_order_value=('revenue', 'mean'),",
        "    order_count=('order_id', 'count'),",
        "    top_customer_revenue=('revenue', 'max')",
        ").reset_index()"
      ],
      "language": "python",
      "highlightLine": 2,
      "annotationText": "Named aggregations: clean column names, multiple metrics in one pass, no postprocessing. Always .reset_index()."
    }
